{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "rpn-desktop-shell",
  "description": "Narrow desktop shell access for the bundled RPN page only.",
  "windows": ["rpn"],
  "permissions": [
    "core:default",
    "allow-desktop-get-state",
    "allow-desktop-open-rpn",
    "allow-desktop-open-st",
    "allow-desktop-reload-active",
    "allow-desktop-open-devtools",
    "allow-desktop-set-st-url",
    "allow-desktop-check-update",
    "allow-desktop-download-update",
    "allow-desktop-install-update",
    "allow-desktop-rpn-flush-complete"
  ]
}
